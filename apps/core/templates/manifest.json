{% load static %}{
    "name": "Home Hub",
    "short_name": "Home Hub",
    "description": "Shopping list, recipes, house construction tracker and time tracking in one place.",
    "start_url": "/",
    "scope": "/",
    "display": "standalone",
    "background_color": "#ffffff",
    "theme_color": "#198754",
    "orientation": "portrait-primary",
    "icons": [
        {
            "src": "{% static 'icon/icon-192.png' %}",
            "sizes": "192x192",
            "type": "image/png"
        },
        {
            "src": "{% static 'icon/icon-512.png' %}",
            "sizes": "512x512",
            "type": "image/png"
        }
    ]
}
